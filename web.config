<?xml version="1.0" encoding="UTF-8"?>
<!-- Configuration IIS pour Лав Кафé -->
<configuration>
    <system.webServer>
        <!-- Gestion des erreurs HTTP -->
        <httpErrors errorMode="Custom" existingResponse="Replace">
            <remove statusCode="404" subStatusCode="-1" />
            <error statusCode="404" path="/templates/404.html" responseMode="ExecuteURL" />
            
            <remove statusCode="403" subStatusCode="-1" />
            <error statusCode="403" path="/templates/404.html" responseMode="ExecuteURL" />
            
            <remove statusCode="500" subStatusCode="-1" />
            <error statusCode="500" path="/templates/404.html" responseMode="ExecuteURL" />
        </httpErrors>
        
        <!-- Désactiver l'affichage des répertoires -->
        <directoryBrowse enabled="false" />
        
        <!-- Compression pour améliorer les performances -->
        <urlCompression doStaticCompression="true" doDynamicCompression="true" />
        
        <!-- En-têtes de sécurité -->
        <httpProtocol>
            <customHeaders>
                <add name="X-Content-Type-Options" value="nosniff" />
                <add name="X-Frame-Options" value="SAMEORIGIN" />
                <add name="X-XSS-Protection" value="1; mode=block" />
            </customHeaders>
        </httpProtocol>
        
        <!-- Cache des ressources statiques -->
        <staticContent>
            <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
        </staticContent>
    </system.webServer>
</configuration>
